# Unwounded AI runtime configuration
# Copy this file to .env and fill values as needed.

# -----------------------------------------------------------------------------
# 1) Runtime model routing
# -----------------------------------------------------------------------------
# LiteLLM model name for drafting. Example: gpt-4o-mini, openai/gpt-4o-mini
LITELLM_MODEL=gpt-4o-mini
# Temperature used by drafting model
LITELLM_TEMPERATURE=0.2
# Required if your selected model provider needs it
OPENAI_API_KEY=

# -----------------------------------------------------------------------------
# 2) L3 Memory (Mem0 Hippocampus)
# -----------------------------------------------------------------------------
# false = in-memory local memory only
# true  = use real Mem0MemoryService
MEM0_ENABLED=false
# Required only when MEM0_ENABLED=true
MEM0_API_KEY=

# -----------------------------------------------------------------------------
# 3) Search provider
# -----------------------------------------------------------------------------
# duckduckgo | tavily | none
SEARCH_PROVIDER=duckduckgo
# Required only when SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
SEARCH_MAX_RESULTS=5
SEARCH_TIMEOUT_SECONDS=8.0

# -----------------------------------------------------------------------------
# 4) Optional observability
# -----------------------------------------------------------------------------
BRAINTRUST_ENABLED=false
BRAINTRUST_PROJECT=unwounded-ai
BRAINTRUST_API_KEY=

LANGSMITH_ENABLED=false
LANGSMITH_PROJECT=unwounded-ai

# -----------------------------------------------------------------------------
# 5) Runtime safety controls
# -----------------------------------------------------------------------------
MAX_RETRIEVAL_ATTEMPTS=2

# -----------------------------------------------------------------------------
# Minimal profile: local/no-key
# -----------------------------------------------------------------------------
# MEM0_ENABLED=false
# SEARCH_PROVIDER=duckduckgo
# BRAINTRUST_ENABLED=false
# LANGSMITH_ENABLED=false

# -----------------------------------------------------------------------------
# Real-memory profile: Mem0 + Tavily
# -----------------------------------------------------------------------------
# MEM0_ENABLED=true
# MEM0_API_KEY=your_mem0_key
# SEARCH_PROVIDER=tavily
# TAVILY_API_KEY=your_tavily_key
# OPENAI_API_KEY=your_model_provider_key
